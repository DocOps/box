# DocOps Box — Project Configuration
# This file is committed to Git. Safe values only — no secrets here.
# For machine-local overrides (UID, GID, private registries), create .env.local (gitignored).
# See README.adoc for full documentation.

# Project Identity
# Slug used for Docker container and volume names. Must be lowercase, no spaces.
# Resolution order if left blank: README.adoc :this_proj_slug: → directory name.
PROJECT_SLUG=my-project

# Image Selection
# Variant: min (Ruby + Pandoc + Vale) or max (+ Node + Python + LibreOffice)
IMAGE_VARIANT=max
# Context: work (interactive, Zsh, Oh-My-Zsh) or live (minimal, for CI)
IMAGE_CONTEXT=work
# Registry: change if using a custom registry or local builds
IMAGE_REGISTRY=docopslab

# Ruby Version
RUBY_VERSION=3.3



# Advanced: Compose File Override
# dxbx looks for .config/docopsbox.yml by default, then falls back to
# docopsbox.yml at project root. To use a different compose file (e.g., if your
# project already has a docker-compose.yml you need to extend), set COMPOSE_FILE
# in your shell environment — .env is not sourced by the shell, so it must be
# exported from your shell profile or set inline:
#
#   export COMPOSE_FILE=./.config/docopsbox.yml   # (explicit default)
#   COMPOSE_FILE=./compose.yml dxbx run           # (one-off override)
#
# Alternatively, add a `include:` block in your .config/docopsbox.yml to pull
# in an existing compose file. See the Docker Compose docs for details.

# Welcome Message (optional)
# Command(s) to run automatically each time you open a shell in the container.
# Commit this in .env for team-wide defaults; override in .config/.env.local
# for personal preferences. Leave blank to skip.
#
# Single command:             DOCOPS_WELCOME_COMMANDS=bundle install
# Chained (one line):         DOCOPS_WELCOME_COMMANDS=bundle install && npm install
# Separate commands (quoted): DOCOPS_WELCOME_COMMANDS="bundle install\nnpm install"
# DOCOPS_WELCOME_COMMANDS=echo "Try 'bundle install' if changes have been made." && ls
