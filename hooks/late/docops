#!/usr/bin/env bash
# /usr/local/bin/docops: DocOps Box container-side CLI
#
# Usage:
#   docops info           Human-readable tool summary
#   docops info --ai      Print LLM-oriented one-liner (for piping/copying)
#   docops help           Show this help
set -euo pipefail

# ---------------------------------------------------------------------------
# Tool registry — canonical list of tools that may be present in the image.
# Format: "DISPLAY_NAME|binary1 binary2 ..."
# The first binary is the probe (used for which); the rest are listed if found.
# Group separators (lines starting with #) are printed as section headers.
# ---------------------------------------------------------------------------
TOOLS=(
  "# Ruby ecosystem"
  "Ruby|ruby bundle gem irb"
  "Asciidoctor|asciidoctor asciidoctor-pdf asciidoctor-epub3"
  "Kramdown-AsciiDoc|kramdoc"
  "Tilt|tilt"
  "Nokogiri|nokogiri"
  "html-proofer|htmlproofer"
  "# Node.js ecosystem"
  "Node.js|node"
  "npm|npm npx"
  "Yarn|yarn"
  "# Python ecosystem"
  "Python 3|python3"
  "pip|pip3 pip"
  "# Document conversion"
  "Pandoc|pandoc"
  "LibreOffice|soffice"
  "unoserver|unoserver"
  "# Documentation linting"
  "Vale|vale"
  "# OpenAPI / API tools"
  "Redocly CLI|redocly"
  "vacuum|vacuum"
  "Speakeasy|speakeasy"
  "# Shell utilities"
  "jq|jq"
  "yq|yq"
  "bat|bat"
  "# Git tools"
  "Git|git"
  "GitHub CLI|gh"
)

_bold()  { printf '\033[1m%s\033[0m' "$*"; }
_green() { printf '\033[32m%s\033[0m' "$*"; }
_grey()  { printf '\033[2m%s\033[0m' "$*"; }

cmd_info() {
  local llm_only=false
  [[ "${1:-}" == "--ai" ]] && llm_only=true

  # Collect present tools into two parallel arrays for the LLM line
  local -a present_names present_bins
  local current_section=""

  for entry in "${TOOLS[@]}"; do
    # Section header
    if [[ "$entry" == "# "* ]]; then
      current_section="${entry:2}"
      continue
    fi

    local name="${entry%%|*}"
    local bins="${entry##*|}"
    local probe="${bins%% *}"

    local probe_path
    probe_path=$(command -v "$probe" 2>/dev/null || true)
    [[ -z "$probe_path" ]] && continue

    # Gather version for key runtimes
    local ver=""
    case "$probe" in
      ruby)    ver=$(ruby --version 2>/dev/null | awk '{print $2}') ;;
      node)    ver=$(node --version 2>/dev/null | tr -d v) ;;
      python3) ver=$(python3 --version 2>/dev/null | awk '{print $2}') ;;
      pandoc)  ver=$(pandoc --version 2>/dev/null | head -1 | awk '{print $2}') ;;
      vale)    ver=$(vale --version 2>/dev/null | awk '{print $NF}') ;;
    esac

    local display="$name"
    [[ -n "$ver" ]] && display="${name} ${ver}"

    # Collect for LLM line — include all available binaries
    local available_bins=""
    for b in $bins; do
      command -v "$b" > /dev/null 2>&1 && available_bins="${available_bins} $b"
    done
    available_bins="${available_bins# }"

    present_names+=("$display")
    present_bins+=("$available_bins")

    if [[ "$llm_only" == false ]]; then
      # Print with section break when section changes
      if [[ "$current_section" != "${_last_section:-}" ]]; then
        printf '\n  %s\n' "$(_grey "$current_section")"
        _last_section="$current_section"
      fi
      printf '  %s %-22s %s\n' "$(_green '✓')" "$(_bold "$display")" "$(_grey "($available_bins)")"
    fi
  done

  if [[ "$llm_only" == false ]]; then
    printf '\n'
    printf '%s\n' "────────────────────────────────────────────────"
    printf '%s\n' "$(_bold 'LLM context (copy and paste into your AI chat):')"
    printf '%s\n' "────────────────────────────────────────────────"
  fi

  # Build the one-liner
  local llm_parts=()
  for i in "${!present_names[@]}"; do
    local bins_str="${present_bins[$i]}"
    # Collapse bin list into parens only when there's more than one
    local word_count
    word_count=$(echo "$bins_str" | wc -w)
    if (( word_count > 1 )); then
      llm_parts+=("${present_names[$i]} (${bins_str// /, })")
    else
      llm_parts+=("${present_names[$i]}")
    fi
  done

  # Join with ", "
  local joined=""
  for part in "${llm_parts[@]}"; do
    joined="${joined:+$joined, }$part"
  done

  local context="${IMAGE_CONTEXT:-unknown}"
  local variant="${IMAGE_VARIANT:-unknown}"
  printf 'I am working inside a DocOps Box container (variant: %s, context: %s).\n' "$variant" "$context"
  printf 'Available CLI tools: %s.\n' "$joined"

  if [[ "$llm_only" == false ]]; then
    printf '%s\n' "────────────────────────────────────────────────"
    printf '\n'
  fi
}

cmd_help() {
  printf '\n%s — DocOps Box container-side CLI\n\n' "$(_bold 'docops')"
  printf '%s\n' "$(_bold 'Commands:')"
  printf '  %-20s %s\n' "info" "List available tools and print an LLM-ready summary"
  printf '  %-20s %s\n' "info --ai" "Print only the LLM one-liner (pipe-friendly)"
  printf '  %-20s %s\n' "help" "Show this help"
  printf '\n'
}

case "${1:-help}" in
  info)   shift; cmd_info "$@" ;;
  help|--help|-h) cmd_help ;;
  *)
    printf 'Unknown command: %s\n' "$1" >&2
    cmd_help >&2
    exit 1
    ;;
esac
